{
    "name": "@reputo/storage",
    "version": "0.0.0",
    "description": "Framework-agnostic S3 storage layer for the Reputo ecosystem.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "private": true,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "type": "module",
    "module": "dist/index.js",
    "scripts": {
        "check": "pnpm exec biome check --write",
        "lint": "pnpm exec biome lint --write",
        "format": "pnpm exec biome format --write",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:cov": "vitest --coverage",
        "typecheck": "tsc --noEmit",
        "build": "tsc",
        "release": "semantic-release",
        "docs": "typedoc",
        "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "catalog:",
        "@aws-sdk/s3-request-presigner": "catalog:"
    },
    "devDependencies": {
        "@semantic-release/changelog": "catalog:",
        "@semantic-release/commit-analyzer": "catalog:",
        "@semantic-release/git": "catalog:",
        "@semantic-release/release-notes-generator": "catalog:",
        "@types/node": "catalog:",
        "semantic-release": "catalog:",
        "semantic-release-commits-lint": "catalog:",
        "tsx": "catalog:",
        "typedoc": "catalog:",
        "typedoc-plugin-markdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "keywords": [
        "typescript",
        "storage",
        "s3"
    ],
    "files": [
        "dist",
        "!dist/**/*.test.*"
    ],
    "author": {
        "name": "Behzad Rabiei",
        "url": "https://github.com/Behzad-rabiei"
    },
    "license": "GPL-3.0",
    "packageManager": "pnpm@10.30.3"
}
