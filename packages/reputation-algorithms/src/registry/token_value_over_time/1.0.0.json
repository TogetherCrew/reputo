                            "dependsOn": "chain",
                            "options": [
                                {
                                    "value": "fet_token",
                                    "label": "FET",
                                    "filterBy": "ethereum"
                                },
                                {
                                    "value": "fet_staking_1",
                                    "label": "FET Staking",
                                    "filterBy": "ethereum"
                                },
                                {
