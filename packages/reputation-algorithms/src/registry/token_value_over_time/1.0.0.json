        }
    ],
    "dependencies": [{ "key": "onchain-data" }],
    "validation": {
        "rules": [
            {
                "kind": "json_chain_coverage",
                "walletInputKey": "wallets",
                "selectorInputKey": "selected_resources",
                "selectorChainField": "chain"
            }
        ]
    },
    "outputs": [
        {
            "key": "token_value_over_time",
            "label": "Token Value Over Time (CSV)",
            "description": "One row per wallet with columns: `wallet_address` and `token_value`.",
            "type": "csv",
            "csv": {
                "hasHeader": true,
                "delimiter": ",",
                "columns": [
                    {
                        "key": "wallet_address",
                        "type": "string",
                        "description": "Wallet address"
                    },
                    {
                        "key": "token_value",
                        "type": "number",
                        "description": "Aggregated token value-over-time score"
                    }
                ]
            }
        },
        {
            "key": "token_value_over_time_details",
            "label": "Token Value Over Time Details (JSON)",
            "description": "Per-wallet resource and lot calculations, useful for auditing results.",
            "type": "json"
        }
    ],
    "runtime": "typescript"
}
