{
    "key": "token_value_over_time",
    "name": "Token Value Over Time",
    "category": "Activity",
    "summary": "Measures wallet holdings of selected tokens, with more weight for longer-held amounts. Each lot gains value over time until it reaches full value after the configured holding period.",
    "description": "### What this algorithm is\nThis algorithm measures a wallet's token holdings for selected chain/token pairs, giving more credit to tokens held longer.\n\nEach incoming transfer creates a separate lot. A new lot starts at zero value and gains value over time until it reaches full value after the maturation threshold.\n\n### How value is calculated\n- Each lot's age is measured in days.\n- Lot value grows linearly from 0 to 100% over the maturation threshold.\n- Once a lot reaches the threshold, it counts at full value.\n\nThe final wallet score is the sum of all remaining lot values across all selected tokens.\n\n### Multiple transfers\n- Every incoming transfer is a separate lot.\n- Outgoing transfers consume the oldest lots first (FIFO).\n- The algorithm evaluates remaining lots at the snapshot run time.\n\n### What data is used\nNo file upload is needed. The algorithm reads indexed token transfer history from the database.\n\n### Outputs\n- A per-wallet CSV with wallet_address and token_value.\n- A JSON details file with per-token and per-lot calculations.",
    "version": "1.0.0",
    "inputs": [
        {
            "key": "maturation_threshold_days",
            "label": "Maturation Threshold (Days)",
            "description": "Number of days a token lot must be held before it reaches full value.",
            "type": "integer",
            "min": 1,
            "max": 3650,
            "default": 90,
            "step": 1,
            "required": true,
            "uiHint": {
                "widget": "number",
                "suffix": "days",
                "presets": [7, 30, 90, 180, 365]
            }
        },
        {
            "key": "selected_assets",
            "label": "Assets to Include",
            "description": "Select one or more supported tokens to include in the score. Holdings across all selected assets are combined into one wallet score.",
            "type": "array",
            "minItems": 1,
            "required": true,
            "uiHint": {
                "widget": "repeater",
                "addButtonLabel": "Add token",
                "presets": [
                    {
                        "label": "FET",
                        "value": [
                            {
                                "chain": "ethereum",
                                "asset_identifier": "0xaea46A60368A7bD060eec7DF8CBa43b7EF41Ad85"
                            },
                            {
                                "chain": "cardano",
                                "asset_identifier": "e824c0011176f0926ad51f492bcc63ac6a03a589653520839dc7e3d9"
                            },
                            { "chain": "cosmos", "asset_identifier": "afet" }
                        ]
                    }
                ]
            },
            "item": {
                "type": "object",
                "properties": [
                    {
                        "key": "chain",
                        "label": "Chain",
                        "description": "Blockchain network for the token.",
                        "type": "string",
                        "enum": ["ethereum", "cardano", "cosmos"],
                        "default": "ethereum",
                        "required": true,
                        "uiHint": {
                            "widget": "select",
                            "options": [
                                { "value": "ethereum", "label": "Ethereum" },
                                { "value": "cardano", "label": "Cardano" },
                                { "value": "cosmos", "label": "Cosmos" }
                            ]
                        }
                    },
                    {
                        "key": "asset_identifier",
                        "label": "Token",
                        "description": "Aset identifier on the selected chain.",
                        "type": "string",
                        "enum": [
                            "0xaea46A60368A7bD060eec7DF8CBa43b7EF41Ad85",
                            "e824c0011176f0926ad51f492bcc63ac6a03a589653520839dc7e3d9",
                            "afet"
                        ],
                        "required": true,
                        "uiHint": {
                            "widget": "select",
                            "dependsOn": "chain",
                            "options": [
                                {
                                    "value": "0xaea46A60368A7bD060eec7DF8CBa43b7EF41Ad85",
                                    "label": "FET",
                                    "filterBy": "ethereum"
                                },
                                {
                                    "value": "e824c0011176f0926ad51f492bcc63ac6a03a589653520839dc7e3d9",
                                    "label": "FET",
                                    "filterBy": "cardano"
                                },
                                {
                                    "value": "afet",
                                    "label": "FET",
                                    "filterBy": "cosmos"
                                }
                            ]
                        }
                    }
                ]
            }
        }
    ],
    "dependencies": [{ "key": "onchain-data" }],
    "outputs": [
        {
            "key": "token_value_over_time",
            "label": "Token Value Over Time by Wallet Address",
            "description": "Per-wallet CSV with columns: wallet_address, token_value (numeric score).",
            "type": "csv",
            "csv": {
                "hasHeader": true,
                "delimiter": ",",
                "columns": [
                    {
                        "key": "wallet_address",
                        "type": "string",
                        "description": "Wallet address"
                    },
                    {
                        "key": "token_value",
                        "type": "number",
                        "description": "Token value over time"
                    }
                ]
            }
        },
        {
            "key": "token_value_over_time_details",
            "label": "Token Value Over Time Details (JSON)",
            "description": "Full per-wallet breakdown including per-token and per-lot calculations. For debugging and auditing.",
            "type": "json"
        }
    ],
    "runtime": "typescript"
}
