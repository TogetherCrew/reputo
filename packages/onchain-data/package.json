{
    "name": "@reputo/onchain-data",
    "version": "0.0.0",
    "description": "TypeScript package for fetching onchain data and persisting to SQLite via Drizzle ORM.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "private": true,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "type": "module",
    "module": "dist/index.js",
    "scripts": {
        "check": "pnpm exec biome check --write",
        "lint": "pnpm exec biome lint --write",
        "format": "pnpm exec biome format --write",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:cov": "vitest --coverage",
        "typecheck": "tsc --noEmit",
        "build": "tsc",
        "docs": "typedoc",
        "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "better-sqlite3": "catalog:",
        "drizzle-orm": "catalog:",
        "p-limit": "catalog:",
        "pino": "catalog:",
        "undici": "catalog:"
    },
    "devDependencies": {
        "@types/better-sqlite3": "catalog:",
        "@types/node": "catalog:",
        "typedoc": "catalog:",
        "typedoc-plugin-markdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "keywords": [
        "typescript",
        "onchain",
        "blockchain",
        "data",
        "sqlite",
        "drizzle"
    ],
    "files": [
        "dist",
        "!dist/**/*.test.*"
    ],
    "author": {
        "name": "Behzad Rabiei",
        "url": "https://github.com/Behzad-rabiei"
    },
    "license": "GPL-3.0",
    "packageManager": "pnpm@10.30.3"
}
