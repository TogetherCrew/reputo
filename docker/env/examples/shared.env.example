# Shared Infrastructure Environment Variables
# Copy this file to shared.env and update with your actual values
# Used by docker-compose.yml for production/staging deployments

# Deployment channel tag
# Use `staging` on the staging host and `production` on the production host.
IMAGE_TAG=staging

# Domain Configuration
TRAEFIK_DOMAIN=traefik.yourdomain.com
UI_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
TEMPORAL_UI_DOMAIN=temporal.yourdomain.com

# Traefik Configuration
# Escape `$` as `$$` for Docker Compose env-file parsing.
TRAEFIK_AUTH=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/
CF_DNS_API_TOKEN=your_cloudflare_api_token_here

# Observability — set in both staging and production
GRAFANA_DOMAIN=grafana.yourdomain.com
# Basic auth for Grafana (htpasswd). Generate: htpasswd -nbB user password, then replace `$` with `$$`.
GRAFANA_AUTH=admin:$$apr1$$xxxxxxxx$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OBSERVABILITY_ENV=production

# CORS Configuration
ALLOWED_ORIGINS=https://app.yourdomain.com

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
