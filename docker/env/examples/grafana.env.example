# Grafana Configuration
# Copy this file to grafana.env and update with your actual values.
# Required for both staging and production; use strong credentials.

# Security — set a strong password in staging and production
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=ChangeMe!!!!

# Server
GF_SERVER_ROOT_URL=https://grafana.yourdomain.com
GF_SERVER_SERVE_FROM_SUB_PATH=false

# Auth — disable signup in production
GF_USERS_ALLOW_SIGN_UP=false
GF_AUTH_ANONYMOUS_ENABLED=false

# Logging
GF_LOG_MODE=console
GF_LOG_LEVEL=warn
