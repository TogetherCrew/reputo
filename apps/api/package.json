{
    "name": "@reputo/api",
    "version": "1.0.0",
    "description": "API for the Reputo ecosystem",
    "private": true,
    "scripts": {
        "build": "nest build",
        "start": "node dist/main",
        "start:dev": "nest start",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "check": "pnpm exec biome check --write",
        "format": "pnpm exec biome format --write",
        "lint": "pnpm exec biome lint --write",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:cov": "vitest --coverage",
        "test:e2e": "vitest --config vitest.config.e2e.ts",
        "test:e2e:watch": "vitest --config vitest.config.e2e.ts --watch",
        "typecheck": "tsc --noEmit",
        "dev": "pnpm run start:dev",
        "release": "semantic-release",
        "clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "catalog:",
        "@aws-sdk/s3-request-presigner": "catalog:",
        "@nestjs/common": "11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "11.0.1",
        "@nestjs/mongoose": "^11.0.3",
        "@nestjs/platform-express": "11.0.1",
        "@nestjs/swagger": "^11.2.1",
        "@reputo/algorithm-validator": "workspace:*",
        "@reputo/database": "workspace:*",
        "@reputo/reputation-algorithms": "workspace:*",
        "@reputo/storage": "workspace:*",
        "@scalar/nestjs-api-reference": "^1.0.5",
        "@temporalio/client": "catalog:",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "compression": "1.8.1",
        "helmet": "8.1.0",
        "joi": "^18.0.1",
        "mongoose": "catalog:",
        "nestjs-pino": "4.4.1",
        "pino-pretty": "catalog:",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "catalog:",
        "@faker-js/faker": "^10.1.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "catalog:",
        "@swc/core": "catalog:",
        "@types/express": "^5.0.0",
        "@types/node": "catalog:",
        "@types/supertest": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "@vitest/spy": "catalog:",
        "mongodb-memory-server": "^10.2.3",
        "semantic-release-commits-lint": "catalog:",
        "supertest": "catalog:",
        "ts-node": "catalog:",
        "tsconfig-paths": "catalog:",
        "typescript": "catalog:",
        "unplugin-swc": "1.5.5",
        "vitest": "catalog:",
        "mongodb":"7.0.0"
    },
    "files": [
        "dist/**"
    ],
    "author": {
        "name": "Behzad Rabiei",
        "url": "https://github.com/Behzad-rabiei"
    },
    "license": "GPL-3.0",
    "packageManager": "pnpm@10.12.4"
}
