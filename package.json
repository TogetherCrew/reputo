{
    "name": "reputo",
    "version": "1.0.0",
    "description": "",
    "private": true,
    "scripts": {
        "dev": "pnpm --filter \"./apps/*\" --parallel dev",
        "start": "pnpm --filter \"./apps/*\" --parallel start",
        "build": "pnpm --filter \"./packages/*\" run build && pnpm --filter \"./apps/*\" run build",
        "clean": "pnpm -r --parallel clean",
        "check": "pnpm -r --parallel check",
        "lint": "pnpm -r --parallel lint",
        "format": "pnpm -r --parallel format",
        "typecheck": "pnpm -r --parallel typecheck",
        "docs": "pnpm -r docs",
        "cz": "cz",
        "release": "pnpm -r --workspace-concurrency=1 release",
        "start:backend": "pnpm --filter @reputo/api dev",
        "start:frontend": "pnpm --filter @reputo/ui dev",
        "start:temporal": "pnpm --filter @reputo/workflows dev",
        "test": "vitest",
        "ci:test": "pnpm --filter \"./packages/*\" run build && pnpm exec vitest run --coverage",
        "postinstall": "command -v git >/dev/null 2>&1 && lefthook install || echo 'Git not found, skipping lefthook install'",
        "algorithm:create": "tsx scripts/create-algorithm.ts",
        "algorithm:validate": "tsx scripts/validate-algorithms.ts"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3"
        ]
    },
    "devDependencies": {
        "@anolilab/semantic-release-pnpm": "catalog:",
        "@biomejs/biome": "catalog:",
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@semantic-release/changelog": "catalog:",
        "@semantic-release/commit-analyzer": "catalog:",
        "@semantic-release/exec": "catalog:",
        "@semantic-release/git": "catalog:",
        "@semantic-release/npm": "catalog:",
        "@semantic-release/release-notes-generator": "catalog:",
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "@vitest/ui": "catalog:",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "lefthook": "^1.11.16",
        "semantic-release": "catalog:",
        "semantic-release-commits-lint": "catalog:",
        "tsconfig-paths": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.30.3"
}
